# 飞书开放平台应用配置
# 见 https://open.feishu.cn/app
# 事件订阅 → 订阅方式 → 选择"长连接"
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude API 配置
# 见 https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 可选配置
CLAUDE_MODEL=claude-sonnet-4-20250514
SYSTEM_PROMPT=你是一个友好的AI助手。请用简洁、准确的方式回答用户的问题。如果不确定答案，请如实告知。
HOST=0.0.0.0
PORT=8000
